{
  "name": "@sophys-web/tiled-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc",
    "clean": "git clean -xdf .turbo .cache dist node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "type-check": "tsc --noEmit --emitDeclarationOnly false",
    "generate-from-spec": "orval --config src/config/orval.config.ts"
  },
  "dependencies": {
    "zod": "catalog:",
    "zod-fetch": "^0.1.1"
  },
  "devDependencies": {
    "@sophys-web/eslint-config": "workspace:*",
    "@sophys-web/prettier-config": "workspace:*",
    "@sophys-web/typescript-config": "workspace:*",
    "typescript": "catalog:"
  },
  "prettier": "@sophys-web/prettier-config"
}
